{
  "manifest_version": 3,
  "name": "Chess Analyzer",
  "version": "1.0.0",
  "description": "Post-game chess analysis with Stockfish engine and AI explanations",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://api.chess.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": ["chess.js", "content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["stockfish.js"],
      "matches": ["https://www.chess.com/*"]
    }
  ]
}
